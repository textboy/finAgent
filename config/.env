RUN_MODE=local

# Production Host
PRODUCTION_HOST=5ngc.s.time4vps.cloud

# Shared Backup Configuration
LLM_BACKUP_MODEL=xiaomi/mimo-v2.5
LLM_BACKUP_URL=https://zenmux.ai/api/v1

# Step 6: Fund Holdings
FUND_HOLDING_MODEL=agnes-2.0-flash
FUND_HOLDING_URL=https://apihub.agnes-ai.com/v1

# Step 8.1: Bull Analysis
BULL_MODEL=xiaomi/mimo-v2.5
BULL_URL=https://zenmux.ai/api/v1

# Step 8.2: Bear Analysis
BEAR_MODEL=anthropic/claude-sonnet-5-free
BEAR_URL=https://zenmux.ai/api/v1

# Step 8.3: Research Debate
DEBATE_MODEL=anthropic/claude-fable-5-free
DEBATE_URL=https://zenmux.ai/api/v1

# Step 9: Trading Plan
TRADING_MODEL=anthropic/claude-fable-5-free
TRADING_URL=https://zenmux.ai/api/v1

# Step 10: Lesson Summary
LESSON_MODEL=agnes-2.0-flash
LESSON_URL=https://apihub.agnes-ai.com/v1

EMBEDDING_MODEL_NAME=openai/text-embedding-3-small
RESULT_DIR=./results
SERVER_HOST=0.0.0.0
QDRANT_HOST=localhost
QDRANT_PORT=6333
UVICORN_PORT=8000
SKIP_RISK_MANAGEMENT=true
# API Keys are provided via environment variables:
# ZENMUX_API_KEY (required) - for https://zenmux* URLs
# AGNES_API_KEY (optional) - for https://apihub.agnes-ai* URLs
# NVIDIA_API_KEY (optional) - for https://integrate.api.nvidia* URLs