RUN_MODE=local
# API keys are provided via environment variables (see start_backend_dev.sh)
# LLM_API_KEY and ALPHA_VANTAGE_API_KEY are exported from system env
LLM_BASE_MODEL=x-ai/grok-beta
EMBEDDING_MODEL_NAME=openai/text-embedding-3-small
LLM_BASE_URL=https://openrouter.ai/api/v1
RESULT_DIR=./results
SERVER_HOST=localhost
QDRANT_PORT=6333
UVICORN_PORT=8000
SKIP_RISK_MANAGEMENT=true