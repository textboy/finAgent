# API keys are provided via environment variables
# FINAGENT_ZENMUX_API_KEY (required) - for https://zenmux* URLs
# AGNES_API_KEY (optional) - for https://apihub.agnes-ai* URLs
# NVIDIA_API_KEY (optional) - for https://integrate.api.nvidia* URLs
LLM_BASE_MODEL=agnes-2.0-flash
LLM_BASE_URL=https://apihub.agnes-ai.com/v1
LLM_BACKUP_MODEL=xiaomi/mimo-v2.5
LLM_BACKUP_URL=https://zenmux.ai/api/v1
EMBEDDING_MODEL_NAME=openai/text-embedding-3-small
RESULT_DIR=./results
QDRANT_PORT=6333
UVICORN_PORT=8000