RUN_MODE=local
# API keys are provided via environment variables (see start_backend_dev.sh)
# LLM_API_KEY is exported from system env (AGNES_API_KEY)
# ZENMUX_API_KEY is provided for backup LLM
LLM_BASE_MODEL=agnes-2.0-flash
LLM_BASE_URL=https://apihub.agnes-ai.com/v1
LLM_BACKUP_MODEL=xiaomi/mimo-v2.5
LLM_BACKUP_URL=https://zenmux.ai/api/v1
EMBEDDING_MODEL_NAME=openai/text-embedding-3-small
RESULT_DIR=./results
SERVER_HOST=localhost
QDRANT_PORT=6333
UVICORN_PORT=8000